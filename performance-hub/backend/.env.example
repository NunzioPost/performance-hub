META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_123456789012345

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DEVELOPER_TOKEN=
GOOGLE_CUSTOMER_ID=
GOOGLE_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v22

FRONTEND_URL=http://localhost:5173

# Persistenza/config su PostgreSQL locale
CONFIG_STORAGE=db
DATABASE_URL=postgresql://performance_hub:performance_hub@localhost:15432/performance_hub
DATABASE_SSL=disable
SIDIAL_PERSISTENCE=db
SIDIAL_SYNC_INTERVAL_MINUTES=18
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_SKIP_LOCAL=true

# SIDIAL resilienza rete/performance
SIDIAL_HTTP_TIMEOUT_MS=15000
SIDIAL_DETAILS_HTTP_TIMEOUT_MS=12000
SIDIAL_ALLOWED_ORDER_SERVICES=Vodafone OutBound,Wind Proprie
SIDIAL_ORDER_SERVICE_FILTER_MODE=contains
ORDERS_ON_DEMAND_ENRICH_MAX=40
ORDERS_ON_DEMAND_ENRICH_CONCURRENCY=6
ORDERS_HISTORICAL_ENRICH_MAX=500
ORDERS_FORCE_SYNC_ENRICH_MAX=200
ORDERS_INLINE_ENRICH_BUDGET_MS=12000
ORDERS_FORCE_SYNC_INLINE_BUDGET_MS=12000

AUTO_ENRICH_ENABLED=true
AUTO_ENRICH_INTERVAL_MINUTES=18
AUTO_ENRICH_DAYS_BACK=3
AUTO_ENRICH_MAX_ORDERS=200
AUTO_ENRICH_START_DELAY_SECONDS=45
SIDIAL_WARMUP_ENABLED=true
SIDIAL_WARMUP_INTERVAL_MINUTES=18
SIDIAL_WARMUP_START_DELAY_SECONDS=75
MARKETING_WARMUP_ENABLED=true
MARKETING_WARMUP_INTERVAL_MINUTES=15
MARKETING_WARMUP_START_DELAY_SECONDS=90
ORDERS_ON_DEMAND_ENRICH_MAX=40
